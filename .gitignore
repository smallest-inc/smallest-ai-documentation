node_modules/
.next/

# Local Playwright MCP outputs
.playwright-mcp/

# Local planning notes — never commit
docs-launch/
# Snippet-generated audio at repo root (running quickstart-style samples
# locally creates output.wav / sync_output.wav / etc. next to the repo).
# Restricted to root with the leading slash so committed audio assets
# under fern/products/waves/.../audio/ stay tracked.
/*.wav

# Python bytecode cache
__pycache__/
*.pyc
.claude/

# Internal-only — auto-loaded by Claude Code at session start; never commit
CLAUDE.md

# Internal operator references — keep out of the public repo.
# docs/ is otherwise used for Fern-rendered assets (CSS, JS, logos),
# so we whitelist those and block bare-doc-folder files.
docs/*.md
docs/*.yml
docs/*.yaml
